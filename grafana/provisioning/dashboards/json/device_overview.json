{
  "title": "IoT Platform - Device Overview",
  "uid": "iot-device-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Devices",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS total FROM devices;",
          "format": "table"
        }
      ]
    },
    {
      "id": 2,
      "title": "Online Devices (last 5 min)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "rawSql": "SELECT count(DISTINCT device_id) AS online FROM device_status WHERE status = 'online' AND time >= now() - interval '5 minutes';",
          "format": "table"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red" }, { "color": "green", "value": 1 }] } } }
    },
    {
      "id": 3,
      "title": "Active Alarms",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS active_alarms FROM alarms WHERE is_active = true;",
          "format": "table"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green" }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 4,
      "title": "Telemetry Points (last hour)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "rawSql": "SELECT count(*) AS points FROM telemetry WHERE time >= now() - interval '1 hour';",
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "title": "Live Telemetry (avg per minute, all devices)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "rawSql": "SELECT bucket AS time, device_id || ' / ' || metric AS metric, avg_value FROM telemetry_1m WHERE $__timeFilter(bucket) ORDER BY bucket;",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 6,
      "title": "MQTT Messages / sec (by topic type)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "rate(mqtt_messages_total[1m])", "legendFormat": "{{topic_type}}" }
      ]
    },
    {
      "id": 7,
      "title": "MQTT Connection State",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "expr": "mqtt_connected" }],
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "Disconnected", "color": "red" }, "1": { "text": "Connected", "color": "green" } } }] } }
    },
    {
      "id": 8,
      "title": "MQTT Reconnects (total)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "expr": "mqtt_reconnects_total" }]
    }
  ]
}
