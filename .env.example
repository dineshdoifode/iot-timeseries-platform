# ---- Postgres / TimescaleDB ----
POSTGRES_USER=iot_admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=iot_platform
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://iot_admin:change_me_strong_password@timescaledb:5432/iot_platform

# ---- MQTT ----
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_USERNAME=iot_service
MQTT_PASSWORD=change_me_mqtt_password
MQTT_CLIENT_ID=iot-worker
MQTT_TELEMETRY_TOPIC=phy/+/telemetry
MQTT_STATUS_TOPIC=phy/+/status
MQTT_KEEPALIVE=60
MQTT_RECONNECT_MIN_DELAY=1
MQTT_RECONNECT_MAX_DELAY=30

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_me_jwt_secret
API_ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- pgAdmin ----
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin_password

# ---- Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# ---- Rate limiting ----
RATE_LIMIT_PER_MINUTE=120

# ---- Alarm notification channels (Phase 6) ----
# All optional — a channel is only used if listed in a rule's notify_channels
# AND its config below is set. MQTT (alarms/{device_id}) always works with no
# extra config as long as the broker is reachable.
ALARM_WEBHOOK_URL=
ALARM_SLACK_WEBHOOK_URL=
ALARM_SMTP_HOST=
ALARM_SMTP_PORT=587
ALARM_EMAIL_FROM=alerts@iot-platform.local
ALARM_EMAIL_TO=
DEVICE_OFFLINE_CHECK_INTERVAL_SECONDS=30
